{% extends 'base.html.twig' %}

{% block title %}My Basket{% endblock %}

{% block body %}
<main class="basket-page">
    <h1>My Basket</h1>

    {% if basket is null or basket.arts is empty %}
        <p class="basket-empty">Your basket is empty.</p>
    {% else %}
        <table class="basket-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Unit price</th>
                    <th>Quantity</th>
                    <th>Subtotal</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% set total = 0 %}
                {% for artBasket in basket.arts %}
                    {% set subtotal = artBasket.art.price * artBasket.amount %}
                    {% set total = total + subtotal %}
                    <tr>
                        <td>{{ artBasket.art.name }}</td>
                        <td>{{ artBasket.art.price }} €</td>
                        <td>{{ artBasket.amount }}</td>
                        <td>{{ subtotal }} €</td>
                        <td>
                            <form method="post" action="{{ path('app_basket_remove', {id: artBasket.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('basket_remove_' ~ artBasket.id) }}">
                                <button type="submit" class="btn btn--danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3"><strong>Total</strong></td>
                    <td colspan="2"><strong>{{ total }} €</strong></td>
                </tr>
            </tfoot>
        </table>

        <a href="#" class="btn btn--primary basket-checkout">Checkout</a>
    {% endif %}

    <a href="{{ path('app_home') }}" class="btn btn--ghost">← Continue shopping</a>
</main>
{% endblock %}
