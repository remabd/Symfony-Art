{% extends 'base.html.twig' %}

{% block title %}My Basket{% endblock %}

{% block body %}
<main class="basket-page">
    <h1>Mon panier</h1>

    {% if basket is null or basket.arts is empty %}
        <p class="basket-empty">Votre panier est vide.</p>
    {% else %}
        <table class="basket-table">
            <thead>
                <tr>
                    <th>Art</th>
                    <th>prix</th>
                    <th>Quantité</th>
                    <th>Sous total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% set total = 0 %}
                {% for artBasket in basket.arts %}
                    {% set subtotal = artBasket.art.price * artBasket.amount %}
                    {% set total = total + subtotal %}
                    <tr>
                        <td>{{ artBasket.art.name }}</td>
                        <td>{{ artBasket.art.price }} €</td>
                        <td class="quantity-cell">
                            <form method="post" action="{{ path('app_basket_update', {id: artBasket.id}) }}" class="quantity-form">
                                <input type="hidden" name="_token" value="{{ csrf_token('basket_update_' ~ artBasket.id) }}">
                                <button type="submit" name="quantity" value="{{ artBasket.amount - 1 }}" class="btn btn--qty">-</button>
                                <span class="quantity-value">{{ artBasket.amount }}</span>
                                <button type="submit" name="quantity" value="{{ artBasket.amount + 1 }}" class="btn btn--qty">+</button>
                            </form>
                        </td>
                        <td>{{ subtotal }} €</td>
                        <td>
                            <form method="post" action="{{ path('app_basket_remove', {id: artBasket.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('basket_remove_' ~ artBasket.id) }}">
                                <button type="submit" class="btn btn--danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3"><strong>Total</strong></td>
                    <td colspan="2"><strong>{{ total }} €</strong></td>
                </tr>
            </tfoot>
        </table>

        <a href="#" class="btn btn--primary basket-checkout">Paiement</a>
    {% endif %}

    <a href="{{ path('app_home') }}" class="btn btn--ghost">← Revenir aux arts</a>
</main>
{% endblock %}
